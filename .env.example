# copy this file to .env and fill in your key
MISTRAL_API_KEY=your_mistral_api_key_here

# optional: change the models if needed
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-medium-latest

# similarity threshold - chunks below this score won't be used
# if all top-k chunks are below, return "insufficient evidence"
SIMILARITY_THRESHOLD=0.5

# chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# file upload limit in MB
MAX_FILE_SIZE_MB=50
